# Server
PORT=3001
FRONTEND_BASE_URL=http://localhost:5173

# GitHub OAuth App — create at https://github.com/settings/applications/new
# Leave empty to use unauthenticated requests (60 req/hr limit)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/github/callback

# Redis (used for caching GitHub API responses)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Python microservice
PYTHON_SERVICE_URL=http://localhost:5000
PYTHON_SERVICE_TIMEOUT_MS=20000

# PostgreSQL (share URLs)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sonification
POSTGRES_PASSWORD=sonification_dev
POSTGRES_DB=sonification
